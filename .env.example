# Copia este archivo como .env y rellena con los datos de tu proyecto Supabase
# (Supabase Dashboard -> Project Settings -> API)

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Solo para notificaciones push reales (se configura en la fase de notificaciones).
# Genera el par de claves con:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
